        <mxCell id="21" value="PATCH /{id}/status\n{status: SUSPENDED}" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;exitX=0;exitY=0.5;entryX=0.5;entryY=0;" edge="1" source="4" target="5" parent="1">
