        <mxCell id="25" value="DELETE /api/sla/{id}" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" source="6" target="7" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
