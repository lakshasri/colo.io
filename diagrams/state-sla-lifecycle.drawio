        <!-- Notes -->
        <mxCell id="30" value="Entry actions:&lt;br/&gt;ACTIVE → System begins monitoring uptime &amp; response times&lt;br/&gt;SUSPENDED → Monitoring paused, SLA clock stopped&lt;br/&gt;EXPIRED → Final state, no further transitions allowed" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" vertex="1" parent="1">
