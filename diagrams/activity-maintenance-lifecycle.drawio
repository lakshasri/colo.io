<mxfile host="app.diagrams.net" modified="2026-04-10" agent="colo.io" version="24.0">
  <diagram id="act-maint" name="Activity — Maintenance Lifecycle">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <mxCell id="2" value="Maintenance Ticket Lifecycle — Command Pattern (Undo/Redo)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="185" y="20" width="720" height="30" as="geometry" />
        </mxCell>

        <!-- Swimlane headers -->
        <mxCell id="3" value="DC_ADMIN / MANAGER" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="4" value="TECHNICIAN" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="460" y="60" width="240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="5" value="System (CommandInvoker)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="850" y="60" width="240" height="40" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="10" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;html=1;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="145" y="125" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="11" value="POST /api/maintenance\n{serverId, title, priority, scheduledAt}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="185" width="220" height="55" as="geometry" />
        </mxCell>

        <!-- CommandInvoker executes ScheduleMaintenanceCommand -->
        <mxCell id="12" value="ScheduleMaintenanceCommand.execute()\nTicket created, status = OPEN\nCommandInvoker pushes to history" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="185" width="300" height="65" as="geometry" />
        </mxCell>

        <!-- NotificationService -->
        <mxCell id="13" value="NotificationService.notifyScheduled()\nPush to /topic/maintenance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="280" width="300" height="55" as="geometry" />
        </mxCell>

        <!-- Manager Approves -->
        <mxCell id="14" value="Manager: PUT /maintenance/{id}/approve\nticket.approved = true, status = PENDING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="370" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Assign Technician -->
        <mxCell id="15" value="DC_ADMIN: PUT /maintenance/{id}/assign\n?technicianId=X" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="460" width="220" height="55" as="geometry" />
        </mxCell>

        <mxCell id="16" value="AssignTechnicianCommand.execute()\nticket.technician = tech\nstatus = IN_PROGRESS candidate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="460" width="300" height="65" as="geometry" />
        </mxCell>

        <!-- Technician starts -->
        <mxCell id="17" value="TECHNICIAN: PUT /maintenance/{id}/start" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="470" y="565" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="18" value="StartMaintenanceCommand.execute()\nstatus = IN_PROGRESS\nstartedAt = now()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="565" width="300" height="65" as="geometry" />
        </mxCell>

        <!-- Server status MAINTENANCE -->
        <mxCell id="19" value="Server.status = MAINTENANCE\n(Observer notifies DashboardObserver)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="470" y="660" width="220" height="55" as="geometry" />
        </mxCell>

        <!-- Decision: complete or cancel -->
        <mxCell id="20" value="Work done?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="745" width="160" height="70" as="geometry" />
        </mxCell>

        <!-- Complete -->
        <mxCell id="21" value="PUT /maintenance/{id}/complete" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="470" y="845" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- Cancel -->
        <mxCell id="22" value="PUT /maintenance/{id}/cancel\n{reason}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="845" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="23" value="CompleteMaintenanceCommand.execute()\nstatus = RESOLVED\nresolvedAt = now()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="845" width="300" height="65" as="geometry" />
        </mxCell>

        <mxCell id="24" value="CancelMaintenanceCommand.execute()\nstatus = CANCELLED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="940" width="300" height="55" as="geometry" />
        </mxCell>

        <!-- Undo/Redo note -->
        <mxCell id="25" value="At any point:\nPOST /commands/undo → reverses last command\nPOST /commands/redo → re-executes undone command" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="940" width="300" height="65" as="geometry" />
        </mxCell>

        <!-- End -->
        <mxCell id="26" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;html=1;shape=doubleEllipse;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="565" y="1045" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="40" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="10" target="11" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="41" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="11" target="12" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="42" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="12" target="13" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
