          <mxGeometry x="765" y="650" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- JwtAuthFilter note -->
        <mxCell id="19" value="JwtAuthFilter intercepts subsequent requests\nand validates Bearer token automatically" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="800" width="230" height="60" as="geometry" />
