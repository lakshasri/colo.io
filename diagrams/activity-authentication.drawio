<mxfile host="app.diagrams.net" modified="2026-04-10" agent="colo.io" version="24.0">
  <diagram id="act-auth" name="Activity — Authentication Flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="Authentication Flow — JWT Login" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="335" y="20" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="3" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;html=1;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="520" y="70" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- Enter credentials -->
        <mxCell id="4" value="User enters username + password" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="415" y="130" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- POST /auth/login -->
        <mxCell id="5" value="POST /api/auth/login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="415" y="210" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- Load user from DB -->
        <mxCell id="6" value="UserDetailsServiceImpl.loadUserByUsername()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="415" y="290" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- Decision: user found? -->
        <mxCell id="7" value="User found in DB?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="370" width="190" height="70" as="geometry" />
        </mxCell>

        <!-- No branch: 401 -->
        <mxCell id="8" value="Return 401 Unauthorized" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="690" y="380" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- BCrypt verify password -->
        <mxCell id="9" value="BCrypt.verify(password, hash)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="415" y="470" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- Decision: password correct? -->
        <mxCell id="10" value="Password correct?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="550" width="190" height="70" as="geometry" />
        </mxCell>

        <!-- No branch: 401 password -->
        <mxCell id="11" value="Return 401 Unauthorized" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="690" y="560" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Generate JWT -->
        <mxCell id="12" value="JwtUtil.generateAccessToken(user, role)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="415" y="650" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- Generate Refresh Token -->
        <mxCell id="13" value="JwtUtil.generateRefreshToken(user)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="415" y="720" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- Return AuthResponse -->
        <mxCell id="14" value="Return 200 AuthResponse {accessToken, refreshToken, role}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="800" width="290" height="50" as="geometry" />
        </mxCell>

        <!-- Store token in localStorage -->
        <mxCell id="15" value="Store token in localStorage\nNavigate to role dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="415" y="880" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- End -->
        <mxCell id="16" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;html=1;shape=doubleEllipse;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="520" y="970" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- Rejected end -->
        <mxCell id="17" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;html=1;shape=doubleEllipse;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="765" y="470" width="30" height="30" as="geometry" />
